# SERVER-SIDE BANKR SECRETS
# Bu dosya ortam değişkenleri (environment variables) örneğidir.
# EĞER Vercel, Netlify veya Cloudflare Workers gibi bir backend kullanıyorsanız
# bu değişkenleri sunucunuzun panelinden güvenli bir şekilde ekleyin.
#
# DİKKAT: Github'a asla gerçek .env dosyanızı (.env.example hariç) YÜKLEMEYİN! 

BANKR_API_KEY=your_real_api_key_here
BANKR_PARTNER_KEY=bk_your_partner_key_here
